# Shopify App Configurations
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app-domain.vercel.app
SCOPES=write_orders,read_orders,read_customers

# Database Configuration (PostgreSQL URL)
DATABASE_URL="postgresql://user:password@localhost:5432/glamhop_returns?schema=public"

# Node environment settings
PORT=3000
